---
layout: default
---
<div class="post">
  <article>
    {% comment %} Hero header — profile photo, name, role, and quick links {% endcomment %}
    <section class="hero-card">
      {% if page.profile and page.profile.image %}
        <div class="hero-photo">
          {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
          {% capture sizes %}(min-width: 576px) 240px, 60vw{% endcapture %}
          {% include figure.liquid loading="eager" path=profile_image_path class="img-fluid" sizes=sizes alt=page.profile.image cache_bust=true %}
        </div>
      {% endif %}

      <div class="hero-body">
        <h1 class="hero-name">
          {% if site.title == 'blank' %}
            {{ site.first_name }} {{ site.middle_name }} {{ site.last_name }}
          {% else %}
            {{ site.title }}
          {% endif %}<span class="hero-degree">, PhD</span>
        </h1>

        {% if page.role %}
          <p class="hero-role">
            {{ page.role }}{% if page.role_org %},
              {% if page.role_url %}<a href="{{ page.role_url }}" target="_blank" rel="noopener">{{ page.role_org }}</a>{% else %}{{ page.role_org }}{% endif %}{% endif %}.
          </p>
        {% endif %}

        {% if page.tagline %}
          <p class="hero-desc">{{ page.tagline }}</p>
        {% endif %}

        <div class="hero-links">
          <a class="hero-btn hero-btn--filled" href="{{ '/cv/' | relative_url }}" aria-label="CV">
            <i class="fa-solid fa-file-lines" aria-hidden="true"></i><span>CV</span>
          </a>
          {% if site.data.socials.scholar_userid %}
            <a class="hero-btn" href="https://scholar.google.com/citations?user={{ site.data.socials.scholar_userid }}" target="_blank" rel="noopener" aria-label="Google Scholar">
              <i class="ai ai-google-scholar" aria-hidden="true"></i><span>Scholar</span>
            </a>
          {% endif %}
          {% if site.data.socials.github_username %}
            <a class="hero-btn" href="https://github.com/{{ site.data.socials.github_username | strip }}" target="_blank" rel="noopener" aria-label="GitHub">
              <i class="fa-brands fa-github" aria-hidden="true"></i><span>GitHub</span>
            </a>
          {% endif %}
          {% if site.data.socials.orcid_id %}
            <a class="hero-btn" href="https://orcid.org/{{ site.data.socials.orcid_id }}" target="_blank" rel="noopener" aria-label="ORCID">
              <i class="ai ai-orcid" aria-hidden="true"></i><span>ORCID</span>
            </a>
          {% elsif site.data.socials.linkedin_username %}
            <a class="hero-btn" href="https://www.linkedin.com/in/{{ site.data.socials.linkedin_username }}" target="_blank" rel="noopener" aria-label="LinkedIn">
              <i class="fa-brands fa-linkedin-in" aria-hidden="true"></i><span>LinkedIn</span>
            </a>
          {% endif %}
          {% if site.data.socials.email %}
            <a class="hero-btn" href="mailto:{{ site.data.socials.email }}" aria-label="Email">
              <i class="fa-regular fa-envelope" aria-hidden="true"></i><span>Email</span>
            </a>
          {% endif %}
        </div>
      </div>
    </section>

    <div class="clearfix">{{ content }}</div>

    <!-- News -->
    {% if page.news and site.announcements and site.announcements.enabled %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">news</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Latest posts -->
    {% if site.latest_posts and site.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">
          selected publications
        </a>
        <small>
          (<a href="https://scholar.google.com/citations?user=Ne1nt4gAAAAJ&hl=en" target="_blank" rel="noopener noreferrer">
            see up-to-date on Google Scholar
          </a>)
        </small>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    <!-- Social -->
    {% if page.social %}
      <div class="social">
        <div class="contact-icons">{% include social.liquid %}</div>
        <div class="contact-note">{{ site.contact_note }}</div>
      </div>
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>

<style>
  .hero-card {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 1.75rem;
    margin-bottom: 2.5rem;
    border-radius: 16px;
    border: 1px solid var(--global-divider-color);
    background: var(--global-card-bg-color);
  }

  .hero-photo {
    flex: 0 0 auto;
  }

  .hero-photo img,
  .hero-photo picture img {
    width: 220px;
    max-width: 40vw;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 16px;
    border: 4px solid var(--global-theme-color);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.12);
  }

  .hero-body {
    flex: 1 1 auto;
    min-width: 0;
  }

  .hero-name {
    margin: 0 0 0.4rem;
    font-weight: 800;
    line-height: 1.1;
    font-size: clamp(1.9rem, 4vw, 2.9rem);
    color: var(--global-text-color);
  }

  .hero-degree {
    color: var(--global-theme-color);
  }

  .hero-role {
    margin: 0 0 0.75rem;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--global-theme-color);
  }

  .hero-role a {
    color: var(--global-theme-color);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .hero-desc {
    margin: 0 0 1.25rem;
    font-size: 1.02rem;
    line-height: 1.55;
    color: var(--global-text-color-light, var(--global-text-color));
    max-width: 46rem;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.05rem;
    border: 1.5px solid var(--global-theme-color);
    border-radius: 999px;
    background: transparent;
    color: var(--global-theme-color);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
  }

  .hero-btn:hover,
  .hero-btn:focus-visible {
    background: var(--global-theme-color);
    color: #ffffff;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.12);
    text-decoration: none;
  }

  .hero-btn--filled {
    background: var(--global-theme-color);
    color: #ffffff;
  }

  .hero-btn--filled:hover,
  .hero-btn--filled:focus-visible {
    filter: brightness(1.08);
    color: #ffffff;
  }

  .hero-btn i {
    font-size: 1em;
  }

  @media (max-width: 600px) {
    .hero-card {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 1.25rem;
      padding: 1.5rem 1.1rem;
    }

    .hero-photo img,
    .hero-photo picture img {
      width: 160px;
      max-width: 55vw;
    }

    .hero-desc {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-links {
      justify-content: center;
    }
  }
</style>
